{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "title": "Uptime",
      "description": "pfSense sysUpTime — SNMP reports it in centiseconds (TimeTicks), so we divide by 100 to feed Grafana's `s` unit.",
      "type": "stat",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "targets": [
        { "expr": "sysUpTime{job=\"snmp_pfsense\"} / 100", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "2": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "3": { "text": "TESTING", "color": "yellow" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 0 },
      "id": 2,
      "title": "Interface oper status",
      "description": "ifOperStatus per interface. 1=up, 2=down, 3=testing, 4=unknown, 5=dormant, 6=notPresent, 7=lowerLayerDown.",
      "type": "stat",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "ifOperStatus{job=\"snmp_pfsense\", ifDescr!~\"lo.*|pflog.*|pfsync.*|enc.*\"}",
          "legendFormat": "{{ifDescr}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bps" } },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "id": 3,
      "title": "Interface throughput — inbound (bits/s)",
      "description": "rate(ifHCInOctets[$__rate_interval]) * 8 per interface. HC counters are 64-bit; the 32-bit ifInOctets wraps every ~30s at gigabit speeds.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(ifHCInOctets{job=\"snmp_pfsense\", ifDescr!~\"lo.*|pflog.*|pfsync.*|enc.*\"}[$__rate_interval]) * 8",
          "legendFormat": "{{ifDescr}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bps" } },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "id": 4,
      "title": "Interface throughput — outbound (bits/s)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(ifHCOutOctets{job=\"snmp_pfsense\", ifDescr!~\"lo.*|pflog.*|pfsync.*|enc.*\"}[$__rate_interval]) * 8",
          "legendFormat": "{{ifDescr}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "pps" } },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "id": 5,
      "title": "Interface errors / discards (per s)",
      "description": "Anything non-zero here is worth a look — bad cable, duplex mismatch, congestion drop.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(ifInErrors{job=\"snmp_pfsense\", ifDescr!~\"lo.*|pflog.*|pfsync.*|enc.*\"}[$__rate_interval])",
          "legendFormat": "in-err {{ifDescr}}",
          "refId": "A"
        },
        {
          "expr": "rate(ifOutErrors{job=\"snmp_pfsense\", ifDescr!~\"lo.*|pflog.*|pfsync.*|enc.*\"}[$__rate_interval])",
          "legendFormat": "out-err {{ifDescr}}",
          "refId": "B"
        },
        {
          "expr": "rate(ifInDiscards{job=\"snmp_pfsense\", ifDescr!~\"lo.*|pflog.*|pfsync.*|enc.*\"}[$__rate_interval])",
          "legendFormat": "in-disc {{ifDescr}}",
          "refId": "C"
        },
        {
          "expr": "rate(ifOutDiscards{job=\"snmp_pfsense\", ifDescr!~\"lo.*|pflog.*|pfsync.*|enc.*\"}[$__rate_interval])",
          "legendFormat": "out-disc {{ifDescr}}",
          "refId": "D"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bps" } },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "id": 6,
      "title": "Link speed (bps)",
      "description": "ifHighSpeed × 1M; a sudden drop usually means link renegotiated to a lower mode (1G → 100M).",
      "type": "timeseries",
      "targets": [
        {
          "expr": "ifHighSpeed{job=\"snmp_pfsense\", ifDescr!~\"lo.*|pflog.*|pfsync.*|enc.*\"} * 1000000",
          "legendFormat": "{{ifDescr}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
