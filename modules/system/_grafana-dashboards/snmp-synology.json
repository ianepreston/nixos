      "id": 4,
      "title": "Uptime",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sysUpTime{job=\"snmp_synology\"} / 100", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "id": 5,
      "title": "CPU load (1m)",
      "description": "laLoadFloat[index=1] from UCD-SNMP — 1-minute load average. Synology exposes laLoadInt/laLoadFloat at index 1/2/3 for 1/5/15-minute windows.",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "expr": "laLoadFloat{job=\"snmp_synology\", laIndex=\"1\"}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "id": 6,
      "title": "Memory used",
      "description": "(memTotalReal - memAvailReal) / memTotalReal — UCD-SNMP memory totals are in KiB; we don't need the absolute value, just the ratio.",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "expr": "(memTotalReal{job=\"snmp_synology\"} - memAvailReal{job=\"snmp_synology\"}) / memTotalReal{job=\"snmp_synology\"} * 100",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "orange", "value": 90 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 4 },
      "id": 7,
      "title": "Volume used %",
      "description": "1 - (raidFreeSize / raidTotalSize). raidName labels each RAID/volume.",
      "type": "stat",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "(1 - raidFreeSize{job=\"snmp_synology\"} / raidTotalSize{job=\"snmp_synology\"}) * 100",
          "legendFormat": "{{raidName}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Normal", "color": "green" } } },
            { "type": "value", "options": { "2": { "text": "Initialized", "color": "green" } } },
            { "type": "value", "options": { "3": { "text": "NotInit", "color": "yellow" } } },
            { "type": "value", "options": { "4": { "text": "SystemPartFailed", "color": "red" } } },
            { "type": "value", "options": { "5": { "text": "Crashed", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "id": 8,
      "title": "Disk status",
