      "type": "stat",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "diskStatus{job=\"snmp_synology\"}",
          "legendFormat": "{{diskID}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
