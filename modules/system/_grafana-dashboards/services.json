{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "percentunit",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "CPU usage by service",
      "description": "CPU time per systemd service / container, taken from cAdvisor at the cgroup level. Includes both native NixOS services (postgresql, authentik, grafana, etc.) and podman containers (visible as podman-<name>.service).",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (id) (rate(container_cpu_usage_seconds_total{id=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "id": 2,
      "title": "Memory (RSS) by service",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (id) (container_memory_rss{id=~\"$service\"})",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "decbytes",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 18 },
      "id": 3,
      "title": "Memory cache by service",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (id) (container_memory_cache{id=~\"$service\"})",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 18 },
      "id": 4,
      "title": "Restarts (15m window)",
      "description": "How many times each service's cgroup was recreated (i.e. restarted) in a rolling 15-minute window.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "changes(container_start_time_seconds{id=~\"$service\"}[15m])",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["homelab", "services", "cadvisor"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(container_cpu_usage_seconds_total{id=~\"/system.slice/[^/]+.service\"}, id)",
        "refresh": 1,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "allValue": "/system.slice/[^/]+.service"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Services (cAdvisor)",
  "uid": "homelab-services",
  "version": 1,
  "weekStart": ""
}
